require "shellwords"

default_platform(:ios)

def app_identifier
  ENV.fetch("APP_IDENTIFIER", "macmini91datepmujubu222.-----------------")
end

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEYFILEPATH"),
    duration: 1200,
    in_house: false
  )
end

def app_review_information_from_env
  required_keys = %w[
    APP_REVIEW_FIRST_NAME
    APP_REVIEW_LAST_NAME
    APP_REVIEW_PHONE
    APP_REVIEW_EMAIL
  ]
  missing = required_keys.select { |key| ENV[key].to_s.strip.empty? }
  UI.user_error!("Missing App Review contact values: #{missing.join(', ')}") unless missing.empty?

  {
    first_name: ENV.fetch("APP_REVIEW_FIRST_NAME"),
    last_name: ENV.fetch("APP_REVIEW_LAST_NAME"),
    phone_number: ENV.fetch("APP_REVIEW_PHONE"),
    email_address: ENV.fetch("APP_REVIEW_EMAIL"),
    demo_user: "",
    demo_password: "",
    notes: ENV.fetch("APP_REVIEW_NOTES", "This app does not require login. No demo account is required.")
  }
end

def project_name
  "猪肉铺店铺管家-分割核算-出肉统计"
end

def mac_archive_path
  "build/#{project_name}-macOS.xcarchive"
end

def app_store_export_options_path
  "scripts/export_options_app_store_connect.plist"
end

def archive_mac_app
  sh([
    "xcodebuild",
    "-project", "#{project_name}.xcodeproj",
    "-scheme", project_name,
    "-configuration", "Release",
    "-destination", "generic/platform=macOS",
    "-allowProvisioningUpdates",
    "clean",
    "archive",
    "-archivePath", mac_archive_path
  ].shelljoin)
end

def upload_mac_archive
  sh([
    "xcodebuild",
    "-exportArchive",
    "-archivePath", mac_archive_path,
    "-exportPath", "build/export-macOS",
    "-exportOptionsPlist", app_store_export_options_path,
    "-allowProvisioningUpdates",
    "-authenticationKeyPath", ENV.fetch("APP_STORE_CONNECT_API_KEY_KEYFILEPATH"),
    "-authenticationKeyID", ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    "-authenticationKeyIssuerID", ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID")
  ].shelljoin)
end

platform :ios do
  desc "Upload App Store metadata only"
  lane :upmeta do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      app_review_information: app_review_information_from_env,
      copyright: ENV.fetch("APP_COPYRIGHT", "2026 liu lei"),
      primary_category: ENV.fetch("APP_PRIMARY_CATEGORY", "BUSINESS")
    )
  end

  desc "Prepare review-required metadata fields without submitting"
  lane :reviewprep do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      copyright: ENV.fetch("APP_COPYRIGHT", "2026 liu lei"),
      primary_category: ENV.fetch("APP_PRIMARY_CATEGORY", "BUSINESS"),
      app_rating_config_path: "fastlane/age_rating_config.json",
      app_review_information: app_review_information_from_env
    )

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
    app = Spaceship::ConnectAPI::App.find(app_identifier)
    app.update(attributes: {
      contentRightsDeclaration: Spaceship::ConnectAPI::App::ContentRightsDeclaration::DOES_NOT_USE_THIRD_PARTY_CONTENT
    })
  end
end

platform :mac do
  desc "Archive and upload a Mac App Store build"
  lane :uploadbuild do
    archive_mac_app
    upload_mac_archive
  end

  desc "Upload Mac App Store metadata only"
  lane :upmeta do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      platform: "osx",
      app_review_information: app_review_information_from_env,
      copyright: ENV.fetch("APP_COPYRIGHT", "2026 liu lei"),
      primary_category: ENV.fetch("APP_PRIMARY_CATEGORY", "BUSINESS")
    )
  end

  desc "Upload Mac App Store screenshots only"
  lane :uppic do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      screenshots_path: "fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      platform: "osx",
      overwrite_screenshots: true
    )
  end

  desc "Prepare Mac review-required metadata fields without submitting"
  lane :reviewprep do
    api_key = asc_api_key
    deliver(
      api_key: api_key,
      app_identifier: app_identifier,
      metadata_path: "fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      force: true,
      platform: "osx",
      copyright: ENV.fetch("APP_COPYRIGHT", "2026 liu lei"),
      primary_category: ENV.fetch("APP_PRIMARY_CATEGORY", "BUSINESS"),
      app_rating_config_path: "fastlane/age_rating_config.json",
      app_review_information: app_review_information_from_env
    )

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
    app = Spaceship::ConnectAPI::App.find(app_identifier)
    app.update(attributes: {
      contentRightsDeclaration: Spaceship::ConnectAPI::App::ContentRightsDeclaration::DOES_NOT_USE_THIRD_PARTY_CONTENT
    })
  end
end
